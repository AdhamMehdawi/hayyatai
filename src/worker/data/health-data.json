    {
      "id": 2,
      "slug": "endometriosis",
      "title_en": "Endometriosis",
      "title_ar": "انتباذ بطانة الرحم",
      "description_en": "Endometriosis is a condition where tissue similar to the uterine lining grows outside the uterus. This tissue responds to hormonal changes during your menstrual cycle, causing pain, inflammation, and sometimes fertility issues. It takes an average of 11+ years to diagnose in the Arab world.",
      "description_ar": "الانتباذ البطاني الرحمي هو حالة ينمو فيها نسيج مشابه لبطانة الرحم خارج الرحم. يستجيب هذا النسيج للتغيرات الهرمونية خلال الدورة الشهرية، مما يسبب الألم والالتهاب وأحيانًا مشاكل في الخصوبة. يستغرق التشخيص في المتوسط أكثر من 11 عامًا في العالم العربي.",
      "prevalence_stat_en": "11+ years to diagnose",
      "prevalence_stat_ar": "+١١ سنة للتشخيص",
      "symptoms": [
        {
          "name_en": "Severe menstrual cramps (dysmenorrhea)",
          "name_ar": "تشنجات شديدة أثناء الدورة الشهرية"
        },
        {
          "name_en": "Chronic pelvic pain",
          "name_ar": "ألم مزمن في الحوض"
        },
        {
          "name_en": "Pain during or after intercourse",
          "name_ar": "ألم أثناء أو بعد العلاقة الحميمة"
        },
        {
          "name_en": "Heavy or irregular bleeding",
          "name_ar": "نزيف غزير أو غير منتظم"
        },
        {
          "name_en": "Pain during bowel movements or urination",
          "name_ar": "ألم أثناء التبرز أو التبول"
        },
        {
          "name_en": "Fatigue and low energy",
          "name_ar": "إرهاق وانخفاض الطاقة"
        },
        {
          "name_en": "Bloating and digestive issues",
          "name_ar": "انتفاخ ومشاكل هضمية"
        },
        {
          "name_en": "Difficulty getting pregnant",
          "name_ar": "صعوبة في الحمل"
        }
      ],
      "risk_factors": [
        {
          "text_en": "Family history of endometriosis",
          "text_ar": "تاريخ عائلي للانتباذ البطاني الرحمي"
        },
        {
          "text_en": "Never having given birth",
          "text_ar": "عدم الإنجاب أبدًا"
        },
        {
          "text_en": "Starting periods at an early age",
          "text_ar": "بدء الدورة الشهرية في سن مبكرة"
        },
        {
          "text_en": "Short menstrual cycles",
          "text_ar": "دورات شهرية قصيرة"
        },
        {
          "text_en": "Heavy periods lasting more than 7 days",
          "text_ar": "دورات غزيرة تستمر أكثر من 7 أيام"
        },
        {
          "text_en": "Low body mass index (BMI)",
          "text_ar": "مؤشر كتلة الجسم المنخفض"
        }
      ],
      "treatments": [
        {
          "text_en": "Pain medications (NSAIDs)",
          "text_ar": "مسكنات الألم (مضادات الالتهاب)"
        },
        {
          "text_en": "Hormonal contraceptives",
          "text_ar": "موانع الحمل الهرمونية"
        },
        {
          "text_en": "Gonadotropin-releasing hormone (GnRH) agonists",
          "text_ar": "ناهضات الهرمون المطلق لموجهة الغدد التناسلية"
        },
        {
          "text_en": "Laparoscopic surgery to remove tissue",
          "text_ar": "جراحة المنظار لإزالة الأنسجة"
        },
        {
          "text_en": "Fertility treatments if needed",
          "text_ar": "علاجات الخصوبة عند الحاجة"
        },
        {
          "text_en": "Complementary therapies (heat, TENS)",
          "text_ar": "العلاجات التكميلية (الحرارة، التحفيز الكهربائي)"
        }
      ],
      "when_to_doctor": [
        {
