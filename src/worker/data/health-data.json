{
  "conditions": [
    {
      "id": 1,
      "slug": "pcos",
      "title_en": "Polycystic Ovary Syndrome (PCOS)",
      "title_ar": "متلازمة تكيّس المبايض",
      "description_en": "PCOS is a hormonal disorder affecting 1 in 5 women in the Gulf region. It occurs when the ovaries produce abnormal amounts of androgens (male hormones), leading to irregular periods, cysts on the ovaries, and various metabolic symptoms.",
      "description_ar": "متلازمة تكيس المبايض هي اضطراب هرموني يؤثر على 1 من كل 5 نساء في منطقة الخليج. تحدث عندما تنتج المبايض كميات غير طبيعية من الأندروجينات (الهرمونات الذكرية)، مما يؤدي إلى عدم انتظام الدورة الشهرية، وتكيسات على المبايض، وأعراض استقلابية مختلفة.",
      "prevalence_stat_en": "1 in 5 Gulf women",
      "prevalence_stat_ar": "١ من كل ٥ نساء خليجيات",
      "symptoms": [
        {
          "name_en": "Irregular or missed periods",
          "name_ar": "دورات شهرية غير منتظمة أو غائبة"
        },
        {
          "name_en": "Excess facial or body hair (hirsutism)",
          "name_ar": "شعر زائد في الوجه أو الجسم"
        },
        {
          "name_en": "Severe acne or oily skin",
          "name_ar": "حب شباب شديد أو بشرة دهنية"
        },
        {
          "name_en": "Weight gain, especially around the abdomen",
          "name_ar": "زيادة الوزن، خاصة حول البطن"
        },
        {
          "name_en": "Thinning hair or hair loss",
          "name_ar": "شعر رقيق أو تساقط الشعر"
        },
        {
          "name_en": "Dark patches of skin (acanthosis nigricans)",
          "name_ar": "بقع داكنة من الجلد"
        },
        {
          "name_en": "Difficulty getting pregnant",
          "name_ar": "صعوبة في الحمل"
        },
        {
          "name_en": "Mood changes or depression",
          "name_ar": "تغيرات في المزاج أو اكتئاب"
        }
      ],
      "risk_factors": [
        {
          "text_en": "Family history of PCOS",
          "text_ar": "تاريخ عائلي لمتلازمة تكيس المبايض"
        },
        {
          "text_en": "Insulin resistance or diabetes",
          "text_ar": "مقاومة الأنسولين أو السكري"
        },
        {
          "text_en": "Obesity or rapid weight gain",
          "text_ar": "السمنة أو زيادة الوزن السريعة"
        },
        {
          "text_en": "High levels of inflammation",
          "text_ar": "مستويات عالية من الالتهاب"
        },
        {
          "text_en": "Genetic predisposition",
          "text_ar": "الاستعداد الوراثي"
        }
      ],
      "treatments": [
        {
          "text_en": "Birth control pills to regulate periods",
          "text_ar": "حبوب منع الحمل لتنظيم الدورة الشهرية"
        },
        {
          "text_en": "Metformin for insulin resistance",
          "text_ar": "ميتفورمين لمقاومة الأنسولين"
        },
        {
          "text_en": "Anti-androgen medications",
          "text_ar": "أدوية مضادة للأندروجين"
        },
        {
          "text_en": "Lifestyle changes (diet & exercise)",
          "text_ar": "تغييرات نمط الحياة (النظام الغذائي والتمارين)"
        },
        {
          "text_en": "Fertility treatments if needed",
          "text_ar": "علاجات الخصوبة عند الحاجة"
        },
        {
          "text_en": "Treatment for excess hair growth",
          "text_ar": "علاج لنمو الشعر الزائد"
        }
      ],
      "when_to_doctor": [
        {
          "text_en": "Missed periods for 3+ months",
          "text_ar": "غياب الدورة الشهرية لمدة 3 أشهر أو أكثر"
        },
        {
          "text_en": "Difficulty getting pregnant after 1 year",
          "text_ar": "صعوبة الحمل بعد سنة واحدة"
        },
        {
          "text_en": "Excessive hair growth or hair loss",
          "text_ar": "نمو الشعر المفرط أو تساقط الشعر"
        },
        {
          "text_en": "Severe acne that won't improve",
          "text_ar": "حب الشباب الشديد الذي لا يتحسن"
        },
        {
          "text_en": "Unexplained weight gain",
          "text_ar": "زيادة الوزن غير المبررة"
        }
      ]
